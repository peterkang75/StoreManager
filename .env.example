# Database — Docker Postgres locally on 5433, Railway internal URL in production
DATABASE_URL=postgresql://postgres:dev@localhost:5433/postgres

# Runtime
NODE_ENV=development
PORT=5000

# OpenAI — supplier invoice parsing (server/invoiceParser.ts, server/routes.ts)
OPENAI_API_KEY=

# Cloudmailin — inbound email webhook Basic auth (server/routes.ts inbound handler)
CLOUDMAILIN_USER=
CLOUDMAILIN_PASS=

# SMTP — outbound email via nodemailer (server/mailer.ts)
SMTP_USER=
SMTP_PASS=

# GuniSMS — outbound SMS for candidate onboarding links (server/sms.ts)
GUNISMS_API_URL=
GUNISMS_API_KEY=
GUNISMS_SENDER_ID=
